# ──────────────────────────────────────────────
# SmartPliegos Backend — Variables de entorno
# Copia este archivo a .env y rellena los valores
# ──────────────────────────────────────────────

# Application
NODE_ENV=development
APP_PORT=3000
APP_NAME=smartpliegos
APP_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_database_password
DB_NAME=smartpliegos

# JWT
# IMPORTANTE: debe tener mínimo 32 caracteres y no ser un placeholder.
# Genera uno seguro con: openssl rand -hex 32
JWT_SECRET=REEMPLAZA_ESTO_CON_UN_SECRET_DE_AL_MENOS_32_CARACTERES_ALEATORIOS
JWT_EXPIRATION=3600

# API
API_VERSION=v1
API_PREFIX=api

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Resend (email transaccional)
# Obtén tu API key en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# Google OAuth (opcional — dejar vacío para desactivar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Sentry (opcional — dejar vacío para desactivar)
# Obtén el DSN en: https://sentry.io → tu proyecto → Settings → Client Keys
SENTRY_DSN=

# Logging
LOG_LEVEL=debug

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads